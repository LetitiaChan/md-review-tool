{
  "name": "md-human-review",
  "displayName": "MD Human Review",
  "description": "Markdown review & annotation tool — Comment, highlight, WYSIWYG edit, Mermaid/KaTeX/PlantUML preview, and generate AI fix instructions. Document reviewer for technical writing | Markdown 批阅批注工具，支持评论、删除标记、所见即所得编辑，一键生成 AI 修改指令",
  "version": "1.1.0",
  "license": "MIT",
  "publisher": "letitia",
  "repository": {
    "type": "git",
    "url": "https://github.com/LetitiaChan/md-review-tool"
  },
  "author": {
    "name": "cauchyhe"
  },
  "contributors": [
    {
      "name": "letitia"
    }
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "keywords": [
    "markdown",
    "review",
    "annotation",
    "WYSIWYG",
    "AI"
  ],
  "icon": "assets/icons/icon-128x128.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "categories": [
    "Education",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onCommand:mdReview.openPanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mdc",
        "extensions": [
          ".mdc"
        ],
        "aliases": [
          "MDC",
          "Markdown Cursor"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mdc",
        "scopeName": "text.html.mdc",
        "path": "./syntaxes/mdc.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "mdReview.openPanel",
        "title": "MD Human Review: 打开批阅面板",
        "icon": "$(edit)"
      },
      {
        "command": "mdReview.exportReview",
        "title": "MD Human Review: 导出批阅记录"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "mdReview.openPanel",
          "when": "resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .mdc",
          "group": "navigation@0"
        }
      ],
      "editor/title": [
        {
          "command": "mdReview.openPanel",
          "when": "resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .mdc",
          "group": "navigation@0"
        }
      ],
      "editor/title/context": [
        {
          "command": "mdReview.openPanel",
          "when": "resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .mdc",
          "group": "navigation@0"
        }
      ],
      "explorer/context": [
        {
          "command": "mdReview.openPanel",
          "when": "resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .mdc",
          "group": "navigation@0"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mdReview.exportReview",
        "key": "ctrl+e",
        "when": "mdReviewPanelFocused"
      },
      {
        "command": "mdReview.openPanel",
        "key": "ctrl+enter",
        "when": "filesExplorerFocus && resourceExtname =~ /^\\.(md|markdown|mdc)$/"
      }
    ],
    "configuration": {
      "title": "MD Human Review",
      "properties": {
        "mdReview.fontSize": {
          "type": "number",
          "default": 18,
          "minimum": 12,
          "maximum": 24,
          "description": "文档正文字体大小（px）"
        },
        "mdReview.lineHeight": {
          "type": "number",
          "default": 1.8,
          "minimum": 1.2,
          "maximum": 2.4,
          "description": "文档正文行高"
        },
        "mdReview.contentMaxWidth": {
          "type": "number",
          "default": 1200,
          "minimum": 600,
          "maximum": 1800,
          "description": "文档内容区最大宽度（px）"
        },
        "mdReview.fontFamily": {
          "type": "string",
          "default": "",
          "description": "文档正文字体（留空使用系统默认，可输入字体名如 'Microsoft YaHei'）"
        },
        "mdReview.codeFontFamily": {
          "type": "string",
          "default": "",
          "description": "代码块字体（留空使用默认等宽字体，可输入字体名如 'Fira Code'）"
        },
        "mdReview.theme": {
          "type": "string",
          "default": "light",
          "enum": [
            "light",
            "dark",
            "auto"
          ],
          "enumDescriptions": [
            "亮色主题",
            "暗色主题",
            "跟随系统"
          ],
          "description": "界面主题"
        },
        "mdReview.showToc": {
          "type": "boolean",
          "default": true,
          "description": "默认显示目录导航栏"
        },
        "mdReview.autoSave": {
          "type": "boolean",
          "default": true,
          "description": "启用批注自动保存"
        },
        "mdReview.autoSaveDelay": {
          "type": "number",
          "default": 1500,
          "minimum": 500,
          "maximum": 10000,
          "description": "自动保存延迟（毫秒）"
        },
        "mdReview.showAnnotations": {
          "type": "boolean",
          "default": true,
          "description": "默认显示批注列表面板"
        },
        "mdReview.sidebarLayout": {
          "type": "string",
          "default": "toc-left",
          "enum": [
            "toc-left",
            "toc-right"
          ],
          "enumDescriptions": [
            "目录在左，批注在右",
            "批注在左，目录在右"
          ],
          "description": "侧边栏布局方式"
        },
        "mdReview.panelMode": {
          "type": "string",
          "default": "floating",
          "enum": [
            "floating",
            "embedded"
          ],
          "enumDescriptions": [
            "悬浮模式（面板覆盖在文档上方）",
            "嵌入模式（面板占据固定宽度）"
          ],
          "description": "侧边面板显示模式"
        },
        "mdReview.documentAlign": {
          "type": "string",
          "default": "center",
          "enum": [
            "left",
            "center",
            "right"
          ],
          "enumDescriptions": [
            "靠左对齐",
            "居中对齐",
            "靠右对齐"
          ],
          "description": "主文档对齐方式"
        },
        "mdReview.enableMermaid": {
          "type": "boolean",
          "default": true,
          "description": "启用 Mermaid 图表渲染"
        },
        "mdReview.enableMath": {
          "type": "boolean",
          "default": true,
          "description": "启用数学公式渲染"
        },
        "mdReview.enablePlantUML": {
          "type": "boolean",
          "default": true,
          "description": "启用 PlantUML 图表渲染（需要网络连接）"
        },
        "mdReview.enableGraphviz": {
          "type": "boolean",
          "default": true,
          "description": "启用 Graphviz 图表渲染"
        },
        "mdReview.showLineNumbers": {
          "type": "boolean",
          "default": false,
          "description": "在代码块中显示行号"
        },
        "mdReview.codeTheme": {
          "type": "string",
          "default": "default-dark-modern",
          "enum": [
            "auto",
            "github",
            "github-dark",
            "monokai",
            "vs2015",
            "atom-one-dark",
            "atom-one-light",
            "dracula",
            "nord",
            "solarized-light",
            "solarized-dark",
            "tokyo-night",
            "one-dark-pro",
            "default-light-modern",
            "default-dark-modern"
          ],
          "enumDescriptions": [
            "自动（跟随界面主题）",
            "GitHub Light",
            "GitHub Dark",
            "Monokai",
            "VS 2015",
            "Atom One Dark",
            "Atom One Light",
            "Dracula",
            "Nord",
            "Solarized Light",
            "Solarized Dark",
            "Tokyo Night",
            "One Dark Pro",
            "Default Light Modern",
            "Default Dark Modern"
          ],
          "description": "代码高亮主题"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "compile:test": "tsc -p ./test/tsconfig.json",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run compile:test",
    "test": "node ./out/test/runTest.js",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.74.0",
    "@viz-js/viz": "^3.25.0",
    "@vscode/test-electron": "^2.3.8",
    "glob": "^10.3.10",
    "marked": "^15.0.12",
    "mocha": "^10.2.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3"
  }
}
